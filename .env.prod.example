# =============================================================================
# RagChatBot — production / Docker environment
# Copy this file to .env.prod and fill in the values marked with CHANGEME
# Format: KEY=VALUE (no "export" prefix — used by Docker env_file)
# =============================================================================

# --- Telegram Bot -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=CHANGEME          # Токен от @BotFather

# --- YandexGPT / Yandex Cloud Foundation Models ----------------------------
OPENAI_FOLDER_ID=CHANGEME            # Folder ID каталога в Yandex Cloud (b1g...)
OPENAI_API_KEY=CHANGEME              # API-ключ сервисного аккаунта (AQV...)
OPENAI_API_BASE=https://llm.api.cloud.yandex.net/v1
EMBEDDING_API=https://llm.api.cloud.yandex.net:443/foundationModels/v1/textEmbedding
MODEL_NAME=yandexgpt
TEMPERATURE=0.1
LLM_MAX_RETRIES=5

# --- Application -----------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=32000
PROJECT_NAME=RagChatBot              # CHANGEME — имя твоего бота
STAGE=prod
TIMEZONE=Europe/Moscow
DEBUG=false
LOCAL=false

# --- ChromaDB ---------------------------------------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
COLLECTION_NAME=CHANGEME             # Придумай имя коллекции (например MY_BOT_COLLECTION)
SIMILARITY_FILTER=1.5
CHROMA_MAX_RAG_DOCUMENTS=42
TIME_SLEEP_RATE_EMBEDDER=0.01

# --- Redis ------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_THRESHOLD=0.05
REDIS_TTL=3600
USER_COUNTER_LIMIT=20
USER_TTL_LIMIT=86400
RATE_LIMIT_TEMPLATE=msg_count:{user_id}

# --- PostgreSQL -------------------------------------------------------------
PG_USER=CHANGEME                     # Придумай имя пользователя БД
PG_PASSWORD=CHANGEME                 # Придумай пароль БД
POSTGRES_DB=CHANGEME                 # Придумай имя базы данных
PG_SCHEMA=public
PG_HOST=postgres
PG_PORT=5432
PG_SSLMODE=disable
HISTORY_LIMIT=10

# --- Langfuse ---------------------------------------------------------------
LANGFUSE_SECRET_KEY=CHANGEME         # sk-lf-... из настроек проекта Langfuse
LANGFUSE_PUBLIC_KEY=CHANGEME         # pk-lf-... из настроек проекта Langfuse
LANGFUSE_HOST=CHANGEME               # https://cloud.langfuse.com или http://localhost:3000
LANGFUSE_STAGE=prod

# --- Logging ---------------------------------------------------------------
LOG_PATH=/opt/app-root/logs
LOG_FILE_NAME=app.log
METRIC_PATH=/opt/app-root/logs
METRIC_FILE_NAME=app-metric.log
AUDIT_LOG_PATH=/opt/app-root/logs
AUDIT_LOG_FILE_NAME=events.log
LOG_ROTATION=10 MB
HOST_IP=0.0.0.0
HOST_UID=00000000-0000-0000-0000-000000000000
