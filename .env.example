# =============================================================================
# RagChatBot — local development environment
# Copy this file to .env and fill in the values marked with CHANGEME
# Usage: source .env  (or use python-dotenv — it is loaded automatically)
# =============================================================================

# --- YandexGPT / Yandex Cloud Foundation Models ----------------------------
# IAM-token or API-key for Yandex Cloud. Obtain via:
#   yc iam create-token  OR  yc iam api-key create --service-account-name <sa>
export OPENAI_FOLDER_ID="b1g_CHANGEME"          # Yandex Cloud folder ID
export OPENAI_API_KEY="AQD_CHANGEME"            # IAM token or API key
export OPENAI_API_BASE="https://llm.api.cloud.yandex.net/v1"
export EMBEDDING_API="https://llm.api.cloud.yandex.net:443/foundationModels/v1/textEmbedding"

# LLM model name (yandexgpt / yandexgpt-lite / yandexgpt-32k etc.)
export MODEL_NAME="yandexgpt"
export TEMPERATURE="0.1"
export LLM_MAX_RETRIES="5"

# --- Application -----------------------------------------------------------
export APP_HOST="0.0.0.0"
export APP_PORT="8080"
export PROJECT_NAME="RagChatBot"
export STAGE="dev"
export TIMEZONE="Europe/Moscow"
export DEBUG="false"
export LOCAL="true"

# --- ChromaDB (vector store) -----------------------------------------------
export CHROMA_HOST="127.0.0.1"
export CHROMA_PORT="8000"
export COLLECTION_NAME="PRODUCTION_COLLECTION"   # CHANGEME — your collection name
export SIMILARITY_FILTER="1.5"
export CHROMA_MAX_RAG_DOCUMENTS="42"
export TIME_SLEEP_RATE_EMBEDDER="0.01"

# --- Redis (semantic cache + rate limiter) ---------------------------------
export REDIS_HOST="127.0.0.1"
export REDIS_PORT="6379"
export REDIS_THRESHOLD="0.05"       # cosine distance threshold for cache hits
export REDIS_TTL="3600"             # cache TTL in seconds
export USER_COUNTER_LIMIT="20"      # max requests per user per window
export USER_TTL_LIMIT="86400"       # rate limit window in seconds (24h)
export RATE_LIMIT_TEMPLATE="msg_count:{user_id}"

# --- PostgreSQL (LangGraph checkpointer) -----------------------------------
export PG_USER="rag_chatbot"                # CHANGEME
export PG_PASSWORD="CHANGEME"
export POSTGRES_DB="rag_chatbot_db"         # CHANGEME
export PG_SCHEMA="public"
export PG_HOST="127.0.0.1"
export PG_PORT="5432"
export PG_SSLMODE="disable"
export HISTORY_LIMIT="10"                   # number of past Q/A pairs stored per user

# --- Langfuse (tracing + prompt management) --------------------------------
export LANGFUSE_SECRET_KEY="sk-lf-CHANGEME"
export LANGFUSE_PUBLIC_KEY="pk-lf-CHANGEME"
export LANGFUSE_HOST="http://127.0.0.1:3000"
export LANGFUSE_STAGE="dev"

# --- Logging ---------------------------------------------------------------
# Paths must exist on disk before starting the service
export LOG_PATH="."
export LOG_FILE_NAME="app.log"
export METRIC_PATH="."
export METRIC_FILE_NAME="app-metric.log"
export AUDIT_LOG_PATH="."
export AUDIT_LOG_FILE_NAME="events.log"
export LOG_ROTATION="10 MB"
export HOST_IP="127.0.0.1"
export HOST_UID="00000000-0000-0000-0000-000000000000"
